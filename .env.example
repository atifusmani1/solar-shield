# Copy to .env and fill in your keys
# Load with: source .env  (bash) or set them manually

# Shodan — https://account.shodan.io/
# Free tier: 100 results/month
# Required for: scripts/03_shodan_search.py
SHODAN_API_KEY=your_shodan_api_key_here

# NVD (optional — no key needed, but lifts rate limit from 5 to 50 req/30s)
# Get free key at: https://nvd.nist.gov/developers/request-an-api-key
# Used by: scripts/01_fetch_nvd_cves.py and scripts/00_sync_vulnerability_data.py
NVD_API_KEY=your_nvd_api_key_here

# Censys (optional — alternative to Shodan)
# Free account: https://search.censys.io/register
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here
